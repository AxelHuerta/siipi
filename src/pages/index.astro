---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Card from "../components/Card.astro";
---

<Layout>
  <Navbar />
  <main class="max-w-[1400px] mx-auto p-4 grid grid-cols-3 gap-4">
    <Card id="profile">
      <ul>
        <li class="text-lg font-bold">Hola, Axel Huerta Hernández</li>
        <li>Matrícula: 123456789</li>
        <li>CBI</li>
        <li>Licenciatura en Computación</li>
        <li>Inscrito a UEA</li>
      </ul>
    </Card>
    <Card id="info" size="col-span-2">
      <h2 class="text-xl font-bold">Información general</h2>
      <ul>
        <li>Dedicación: Tiempo Completo</li>
        <li>Créditos inscritos: 44</li>
        <li>Clave del plan: 30</li>
        <li>Trimestre de ingreso: 19O</li>
        <li>Último trimestre ingreso: 24O</li>
        <li>Créditos contabilizados: 408</li>
        <li>Email: axelhuerta@dev</li>
      </ul>
    </Card>
    <section id="schedule" class="bg-purple-300 col-span-3 min-h-[300px]">
      <h2>Aquí el horario</h2>
    </section>
    <section id="links" class="bg-yellow-300">
      <ul>
        <li><a href="">Módulo de Información Escolar</a></li>
        <li><a href="">UAMI con Perspectiva de Género</a></li>
      </ul>
    </section>
    <section id="tutorias" class="bg-gray-300 col-span-2">
      <h2>Aquí eso de las tutorias</h2>
    </section>
  </main>
</Layout>
